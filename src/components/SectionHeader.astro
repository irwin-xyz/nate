---
import { formatDate, generatedAt } from "../lib/site.js";
import Coordinate from "./Coordinate.astro";

const { title, body, source, eyebrow } = Astro.props;
---
<header class="section-header">
  {eyebrow && <Coordinate label={eyebrow} tick />}
  <h1>{title}</h1>
  <p>{body}</p>
  <p class="source-note">Generated {formatDate(generatedAt)} from {source}.</p>
</header>
