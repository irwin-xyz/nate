---
// Light/dark toggle. The no-flash script in Layout.astro sets the initial
// theme before paint; this just flips and persists the choice.
---
<button
  type="button"
  class="theme-toggle"
  aria-label="Toggle color theme"
  title="Toggle light / dark"
  data-theme-toggle
>
  <svg class="theme-toggle__sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
    <circle cx="12" cy="12" r="4.2"></circle>
    <path d="M12 2.5v2.4M12 19.1v2.4M4.4 4.4l1.7 1.7M17.9 17.9l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.4 19.6l1.7-1.7M17.9 6.1l1.7-1.7"></path>
  </svg>
  <svg class="theme-toggle__moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20 14.2A8.2 8.2 0 1 1 9.8 4a6.4 6.4 0 0 0 10.2 10.2z"></path>
  </svg>
</button>
<script is:inline>
  (function () {
    var btn = document.currentScript.previousElementSibling;
    if (!btn) btn = document.querySelector("[data-theme-toggle]");
    btn.addEventListener("click", function () {
      var root = document.documentElement;
      var current =
        root.getAttribute("data-theme") ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      var next = current === "dark" ? "light" : "dark";
      root.setAttribute("data-theme", next);
      try {
        localStorage.setItem("theme", next);
      } catch (e) {}
    });
  })();
</script>
